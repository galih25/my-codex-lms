<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - MyCodex LMS</title>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <header class="site-header">
        <div class="container nav-shell">
            <a class="brand" asp-controller="Home" asp-action="Index">MyCodex LMS</a>
            <nav>
                <a asp-controller="Home" asp-action="Index">Dashboard</a>
                <a asp-controller="Courses" asp-action="Index">Courses</a>
                <a asp-controller="Courses" asp-action="Create">Add Course</a>
            </nav>
        </div>
    </header>

    <main class="container content-shell">
        @RenderBody()
    </main>
</body>
</html>
